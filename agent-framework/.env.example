# Azure OpenAI used by every agent (orchestrator + specialists).
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-10-21

# Optional: separate (usually larger) model used by eval_runner.py as the judge.
# Falls back to AZURE_OPENAI_DEPLOYMENT if unset.
JUDGE_OPENAI_ENDPOINT=
JUDGE_MODEL_DEPLOYMENT_NAME=
